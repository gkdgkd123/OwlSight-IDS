# SemFlow-IDS 配置文件示例
# 复制此文件为 .env 并填入实际值

# ============================================================================
# Redis 配置
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TTL=60

# ============================================================================
# Suricata 配置
# ============================================================================
SURICATA_EVE_PATH=/var/log/suricata/eve.json
SURICATA_TAIL_INTERVAL=0.1

# ============================================================================
# Scapy 抓包配置
# ============================================================================
SCAPY_INTERFACE=eth0
SCAPY_PACKET_TRIGGER=10
SCAPY_TIME_TRIGGER=3.0
SCAPY_BPF_FILTER=

# ============================================================================
# XGBoost 模型配置
# ============================================================================
XGB_MODEL_PATH=./src/models/xgb_model.json
XGB_THRESHOLD_HIGH=0.9
XGB_THRESHOLD_LOW=0.5
ANOMALY_THRESHOLD=0.75

# ============================================================================
# LLM 配置
# ============================================================================
# 是否使用 API 模式（true/false）
LLM_USE_API=true

# API 配置（use_api=true 时使用）
LLM_API_BASE_URL=https://openai.com/v1
LLM_API_KEY=your_api_key_here
LLM_API_MODEL=claude-opus-4-6

# 本地模型配置（use_api=false 时使用）
LLM_MODEL_PATH=./models/Qwen-3B
LLM_VECTOR_DB_PATH=./src/models/vector_db
LLM_USE_RAG=false
LLM_MAX_LENGTH=512

# ============================================================================
# 系统配置
# ============================================================================
LOG_LEVEL=INFO
